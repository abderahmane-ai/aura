import std.test as test
import std.nn as nn
import std.optim as optim
import std.data.loader as loader
import std.nn.trainer as trainer
import std.tensor as tensor
import std.data.text as text
import std.fs as fs

fn main():
    let cnn = nn.sequential([nn.conv2d(1, 4, 3, 1, 1), nn.relu(), nn.max_pool2d(2), nn.adaptive_avg_pool2d([1, 1]), nn.flatten(), nn.linear(4, 2)])
    let image = tensor.tensor([[[[0.0, 1.0, 0.0, 1.0], [0.0, 1.0, 0.0, 1.0], [0.0, 1.0, 0.0, 1.0], [0.0, 1.0, 0.0, 1.0]]]])
    let cnn_out = cnn.forward(image)
    test.assert_equal(cnn_out.data.shape()[0], 1)
    test.assert_equal(cnn_out.data.shape()[1], 2)

    let tok = text.tokenizer()
    let vocab = text.vocab()
    vocab.fit([tok.tokenize("good aura"), tok.tokenize("bad bug")])
    let embed = nn.embedding(vocab.size(), 6)
    let embed_out = embed.forward(tensor.tensor([[float(vocab.token_to_id("good")), float(vocab.token_to_id("aura"))]]))
    test.assert_equal(embed_out.data.shape()[0], 1)
    test.assert_equal(embed_out.data.shape()[1], 2)
    test.assert_equal(embed_out.data.shape()[2], 6)

    let gru = nn.gru(6, 8)
    let gru_out = gru.forward(embed_out)
    test.assert_equal(gru_out.data.shape()[0], 1)
    test.assert_equal(gru_out.data.shape()[1], 8)

    let lstm = nn.lstm(6, 8)
    let lstm_state = lstm.run_sequence(embed_out)
    test.assert_equal(lstm_state["hidden"].data.shape()[1], 8)
    test.assert_equal(lstm_state["cell"].data.shape()[1], 8)

    let train = __tiny_bars_dataset(24)
    let train_loader = loader.data_loader(loader.tensor_dataset(train["X"], train["y"]), 8, true, false, 5)
    let fit = trainer.trainer("classification", optim.adam(0.02), nil, nil, {"epochs": 12, "seed": 5, "verbose": false, "device": "cpu"})
    fit.fit(cnn, train_loader, train_loader)
    let stats = fit.evaluate(cnn, train_loader)
    test.assert_true(stats["accuracy"] >= 0.8)

    let seq_model = nn.sequential([nn.embedding(vocab.size(), 6), nn.gru(6, 8), nn.linear(8, 2)])
    let text_x = tensor.tensor([[float(vocab.token_to_id("good")), float(vocab.token_to_id("aura"))], [float(vocab.token_to_id("bad")), float(vocab.token_to_id("bug"))]])
    let text_y = tensor.tensor([1.0, 0.0])
    let text_loader = loader.data_loader(loader.tensor_dataset(text_x, text_y), 2, true, false, 4)
    let fit_text = trainer.trainer("classification", optim.adam(0.03), nil, nil, {"epochs": 25, "seed": 4, "verbose": false, "device": "cpu"})
    fit_text.fit(seq_model, text_loader, text_loader)
    let text_stats = fit_text.evaluate(seq_model, text_loader)
    test.assert_true(text_stats["accuracy"] >= 0.9)

    let dir = fs.temp_dir("aura-cnn-rnn-")
    let path = fs.join([dir, "seq_model.json"])
    seq_model.save(path)
    let restored = nn.load(path)
    let before = seq_model.forward(text_x).data.to_list()
    let after = restored.forward(text_x).data.to_list()
    test.assert_approx(before[0][0], after[0][0], 0.000001)
    test.assert_approx(before[1][1], after[1][1], 0.000001)

fn __tiny_bars_dataset(n: Int):
    let xs = []
    let ys = []
    var i = 0
    while i < n:
        let label = i % 2
        xs.push([__tiny_bar(label)])
        ys.push(float(label))
        i += 1
    return {"X": tensor.tensor(xs), "y": tensor.tensor(ys)}

fn __tiny_bar(label: Int):
    let image = []
    var y = 0
    while y < 4:
        let row = []
        var x = 0
        while x < 4:
            var value = 0.0
            if label == 0 and x >= 1 and x <= 2:
                value = 1.0
            if label == 1 and y >= 1 and y <= 2:
                value = 1.0
            row.push(value)
            x += 1
        image.push(row)
        y += 1
    return image
