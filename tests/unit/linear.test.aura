import std.test as test
import std.math as math
import std.tensor as tensor
import std.ml.linear as linear

fn make_linear(n: Int, d: Int, noise: Float64, seed: Int):
    let rng = math.rng(seed)
    let w = []
    var j = 0
    while j < d:
        w.push(math.rand(rng, -2.0, 2.0))
        j += 1
    let b = 0.4
    let X = []
    let y = []
    var i = 0
    while i < n:
        let row = []
        j = 0
        while j < d:
            row.push(math.rand(rng, -1.0, 1.0))
            j += 1
        var acc = 0.0
        j = 0
        while j < d:
            acc += float(row[j]) * float(w[j])
            j += 1
        let eps = math.rand(rng, -noise, noise)
        y.push(acc + b + eps)
        X.push(row)
        i += 1
    return {"X": tensor.tensor(X), "y": tensor.tensor(y)}

fn main():
    let data = make_linear(260, 3, 0.05, 7)

    let model = linear.ridge(3, 0.001)
    let before = model.loss(data["X"], data["y"], 0.0, 0.0)
    let opts = {"epochs": 200, "lr": 0.08, "batch_size": 64, "seed": 7}
    model.fit(data["X"], data["y"], opts)
    let after = model.loss(data["X"], data["y"], 0.0, 0.0)
    test.assert_true(before > after)

    let model2 = linear.lasso(3, 0.002)
    let before2 = model2.loss(data["X"], data["y"], 0.0, 0.0)
    let opts2 = {"epochs": 220, "lr": 0.07, "batch_size": 64, "seed": 9}
    model2.fit(data["X"], data["y"], opts2)
    let after2 = model2.loss(data["X"], data["y"], 0.0, 0.0)
    test.assert_true(before2 > after2)

    let preds = model.predict(data["X"])
    test.assert_equal(preds.shape()[0], data["X"].shape()[0])
