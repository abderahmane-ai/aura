import std.test as test
import std.tensor as tensor

fn main():
    let a = tensor.tensor([[1, 2], [3, 4]])
    let shape = a.shape()
    test.assert_equal(shape[0], 2)
    test.assert_equal(shape[1], 2)
    test.assert_equal(a.rank(), 2)

    let added = a.add(1).to_list()
    test.assert_equal(added[0][0], 2)
    test.assert_equal(added[1][1], 5)

    let v1 = tensor.tensor([1, 2, 3])
    let v2 = tensor.tensor([4, 5, 6])
    test.assert_equal(v1.dot(v2), 32)

    let m1 = tensor.tensor([[1, 2, 3], [4, 5, 6]])
    let m2 = tensor.tensor([[7, 8], [9, 10], [11, 12]])
    let mm = m1.matmul(m2).to_list()
    test.assert_equal(mm[0][0], 58)
    test.assert_equal(mm[0][1], 64)
    test.assert_equal(mm[1][0], 139)
    test.assert_equal(mm[1][1], 154)

    let reshaped = tensor.tensor([1, 2, 3, 4]).reshape([2, 2]).transpose().to_list()
    test.assert_equal(reshaped[0][0], 1)
    test.assert_equal(reshaped[0][1], 3)
    test.assert_equal(reshaped[1][0], 2)
    test.assert_equal(reshaped[1][1], 4)

    let s = tensor.tensor([0]).sigmoid().to_list()
    test.assert_approx(s[0], 0.5, 0.000001)

    let z = tensor.zeros([2, 3])
    test.assert_equal(z.len(), 6)
    test.assert_equal(z.sum(), 0)

    let e = tensor.eye(3).to_list()
    test.assert_equal(e[0][0], 1)
    test.assert_equal(e[0][1], 0)
    test.assert_equal(e[1][1], 1)

    let b = tensor.tensor([[1, 2, 3], [4, 5, 6]])
    let broadcast = b.add(tensor.tensor([10, 20, 30])).to_list()
    test.assert_equal(broadcast[0][0], 11)
    test.assert_equal(broadcast[1][2], 36)

    let colsum = b.sum_axis(0).to_list()
    let rowsum = b.sum_axis(1).to_list()
    test.assert_equal(colsum[0], 5)
    test.assert_equal(colsum[2], 9)
    test.assert_equal(rowsum[0], 6)
    test.assert_equal(rowsum[1], 15)

    let probs = tensor.tensor([1.0, 2.0, 3.0]).softmax().to_list()
    test.assert_approx(probs[0] + probs[1] + probs[2], 1.0, 0.000001)

    let pred = tensor.tensor([0.9, 0.1, 0.8, 0.2])
    let target = tensor.tensor([1.0, 0.0, 1.0, 0.0])
    let bce = tensor.bce_loss(pred, target)
    test.assert_true(bce > 0)

    let mse = tensor.mse_loss(tensor.tensor([1, 2, 3]), tensor.tensor([1, 3, 2]))
    test.assert_approx(mse, 0.6666666667, 0.000001)

    let n = tensor.tensor([3.0, 4.0]).normalize().to_list()
    test.assert_approx(n[0], 0.6, 0.000001)
    test.assert_approx(n[1], 0.8, 0.000001)

    let inplace = tensor.tensor([1, 2, 3])
    inplace.add_(2)
    test.assert_equal(inplace.to_list()[0], 3)
    test.assert_equal(inplace.to_list()[2], 5)

    let r = tensor.rand([2, 2], -1, 1)
    test.assert_equal(r.shape()[0], 2)
    test.assert_equal(r.shape()[1], 2)

    let hot = tensor.one_hot([0, 2], 3).to_list()
    test.assert_equal(hot[0][0], 1)
    test.assert_equal(hot[0][1], 0)
    test.assert_equal(hot[1][2], 1)

    let idx = tensor.tensor([[5, 6], [7, 8]])
    test.assert_equal(tensor.at2(idx, 1, 0), 7)
    tensor.set_at2(idx, 1, 1, 9)
    test.assert_equal(tensor.at2(idx, 1, 1), 9)

    let stdz = tensor.standardize(tensor.tensor([1.0, 2.0, 3.0, 4.0]))
    test.assert_approx(stdz.mean(), 0.0, 0.000001)

    let scaled = tensor.min_max_scale(tensor.tensor([2.0, 4.0, 6.0])).to_list()
    test.assert_approx(scaled[0], 0.0, 0.000001)
    test.assert_approx(scaled[2], 1.0, 0.000001)

    let ce_probs = tensor.cross_entropy_loss(tensor.tensor([[0.7, 0.2, 0.1], [0.1, 0.2, 0.7]]), [0, 2])
    test.assert_true(ce_probs > 0)

    let logits = tensor.tensor([[2.0, 1.0, 0.1], [0.1, 0.5, 1.5]])
    let ce_logits = tensor.cross_entropy_with_logits(logits, [0, 2])
    test.assert_true(ce_logits > 0)

    let acc = tensor.classification_accuracy(logits, [0, 2])
    test.assert_approx(acc, 1.0, 0.000001)

    let bacc = tensor.binary_accuracy([0.9, 0.2, 0.7, 0.4], [1, 0, 1, 0])
    test.assert_approx(bacc, 1.0, 0.000001)

    let xu = tensor.xavier_uniform([4, 3], 3, 4)
    test.assert_equal(xu.shape()[0], 4)
    test.assert_equal(xu.shape()[1], 3)

    let xn = tensor.xavier_normal([4, 3], 3, 4)
    test.assert_equal(xn.shape()[0], 4)
    test.assert_equal(xn.shape()[1], 3)

    let hu = tensor.he_uniform([3, 2], 2)
    test.assert_equal(hu.shape()[0], 3)
    test.assert_equal(hu.shape()[1], 2)

    let hn = tensor.he_normal([3, 2], 2)
    test.assert_equal(hn.shape()[0], 3)
    test.assert_equal(hn.shape()[1], 2)