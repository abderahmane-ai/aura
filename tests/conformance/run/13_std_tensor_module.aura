import std.tensor as tensor
import std.io as io

fn main():
    let a = tensor.tensor([[1, 2], [3, 4]])
    let b = tensor.tensor([[10, 20], [30, 40]])
    let c = a.add(b)
    let cl = c.to_list()
    if cl[0][0] != 11 or cl[1][1] != 44:
        panic("tensor add failed")

    let v1 = tensor.tensor([1, 2, 3])
    let v2 = tensor.tensor([4, 5, 6])
    if tensor.dot(v1, v2) != 32:
        panic("tensor dot failed")

    let m = tensor.matmul(a, tensor.tensor([[1, 0], [0, 1]])).to_list()
    if m[0][1] != 2 or m[1][0] != 3:
        panic("tensor matmul failed")

    io.println("std.tensor ok")
