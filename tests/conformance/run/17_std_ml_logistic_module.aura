import std.io as io
import std.data.synthetic as synthetic
import std.ml.logistic as logistic

fn main():
    let data = synthetic.binary_linear(220, 3, 0.12, 3)
    let split = synthetic.train_test_split(data["X"], data["y"], 0.25, true, 10)

    let model = logistic.init(3, 1)
    let options = {"epochs": 110, "lr": 0.2, "batch_size": 32, "seed": 4}
    logistic.fit(model, split["X_train"], split["y_train"], options)

    let metrics = logistic.evaluate(model, split["X_test"], split["y_test"])
    if metrics["accuracy"] < 0.85:
        panic("logistic synthetic accuracy below threshold")

    io.println("std.ml.logistic ok")