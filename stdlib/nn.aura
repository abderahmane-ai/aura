class FlattenImpl:
    let kind: String
    var training: Bool
    let start_dim: Int
    let end_dim: Int

    fn init(start_dim: Int = 1, end_dim: Int = -1):
        self.kind = "flatten"
        self.training = true
        self.start_dim = start_dim
        self.end_dim = end_dim

    fn forward(x):
        let input = __as_variable(x)
        let shape = input.data.shape()
        let rank = len(shape)
        var start = self.start_dim
        var stop = self.end_dim
        if start < 0:
            start += rank
        if stop < 0:
            stop += rank
        if start < 0 or stop < start or stop >= rank:
            panic("nn.Flatten invalid dims")
        let out_shape = []
        var i = 0
        while i < start:
            out_shape.push(shape[i])
            i += 1
        let merged = 1
        i = start
        while i <= stop:
            merged *= shape[i]
            i += 1
        out_shape.push(merged)
        while i < rank:
            out_shape.push(shape[i])
            i += 1
        return input.reshape(out_shape)

    fn parameters():
        return []

    fn named_parameters():
        return []

    fn buffers():
        return []

    fn train():
        self.training = true
        return self

    fn eval():
        self.training = false
        return self

    fn zero_grad():
        return self

    fn to(device: String):
        return self

    fn cpu():
        return self

    fn cuda(device: String = "cuda:0"):
        return self

    fn state_dict():
        return {}

    fn load_state_dict(state):
        return self

    fn save(path: String):
        return save(self, path)

fn Flatten(start_dim: Int = 1, end_dim: Int = -1):
    return FlattenImpl(start_dim, end_dim)

fn flatten(start_dim: Int = 1, end_dim: Int = -1):
    return Flatten(start_dim, end_dim)

class Conv2dImpl:
    let kind: String
    var training: Bool
    let in_channels: Int
    let out_channels: Int
    let kernel_size
    let stride
    let padding
    let dilation
    let bias_enabled: Bool
    var weight
    var bias

    fn init(in_channels: Int, out_channels: Int, kernel_size, stride = 1, padding = 0, dilation = 1, bias: Bool = true):
        if in_channels <= 0 or out_channels <= 0:
            panic("nn.Conv2d expects in_channels > 0 and out_channels > 0")
        self.kind = "conv2d"
        self.training = true
        self.in_channels = in_channels
        self.out_channels = out_channels
        self.kernel_size = __pair(kernel_size)
        self.stride = __pair(stride)
        self.padding = __pair(padding)
        self.dilation = __pair(dilation)
        self.bias_enabled = bias
        self.weight = Parameter(tensor.zeros([out_channels, in_channels, self.kernel_size[0], self.kernel_size[1]]), "weight")
        if bias:
            self.bias = Parameter(tensor.zeros([out_channels]), "bias")
        else:
            self.bias = nil
        __apply_conv_init(self)

    fn forward(x):
        return functional.conv2d(__as_variable(x), self.weight, self.bias, self.stride, self.padding, self.dilation)

    fn parameters():
        return parameters(self)

    fn named_parameters():
        return named_parameters(self)

    fn buffers():
        return buffers(self)

    fn train():
        return train(self)

    fn eval():
        return eval(self)

    fn zero_grad():
        return zero_grad(self)

    fn to(device: String):
        return to(self, device)

    fn cpu():
        return cpu(self)

    fn cuda(device: String = "cuda:0"):
        return cuda(self, device)

    fn state_dict():
        return state_dict(self)

    fn load_state_dict(state):
        return load_state_dict(self, state)

    fn save(path: String):
        return save(self, path)

fn Conv2d(in_channels: Int, out_channels: Int, kernel_size, stride = 1, padding = 0, dilation = 1, bias: Bool = true):
    return Conv2dImpl(in_channels, out_channels, kernel_size, stride, padding, dilation, bias)

