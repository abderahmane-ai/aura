module std.nn

import std.autograd as autograd
import std.tensor as tensor
import std.fs as fs
import std.nn.functional as functional
import std.nn.init as init

let SERIAL_VERSION = 1

class Module:
    let kind: String
    var training: Bool

    fn init(kind: String = "module"):
        self.kind = kind
        self.training = true

    fn forward(x):
        panic("nn.Module.forward not implemented")

    fn parameters():
        return parameters(self)

    fn named_parameters():
        return named_parameters(self)

    fn buffers():
        return buffers(self)

    fn train():
        return train(self)

    fn eval():
        return eval(self)

    fn zero_grad():
        return zero_grad(self)

    fn state_dict():
        return state_dict(self)

    fn load_state_dict(state):
        return load_state_dict(self, state)

    fn save(path: String):
        return save(self, path)

class Parameter:
    let kind: String
    let requires_grad: Bool
    var data
    var grad
    var name: String

    fn init(data, name: String = ""):
        self.kind = "parameter"
        self.requires_grad = true
        self.data = tensor.tensor(data)
        self.grad = nil
        self.name = name

    fn variable():
        return autograd.leaf(self.data, true, self)

    fn zero_grad():
        if self.grad != nil:
            self.grad.fill_(0.0)
        return self

fn parameter(data, name: String = ""):
    return Parameter(data, name)

class Linear:
    let kind: String
    var training: Bool
    let in_features: Int
    let out_features: Int
    let bias_enabled: Bool
    let init_name: String
    var weight
    var bias

    fn init(in_features: Int, out_features: Int, bias: Bool = true, init_name: String = "xavier_uniform"):
        if in_features <= 0 or out_features <= 0:
            panic("nn.Linear expects in_features > 0 and out_features > 0")
        self.kind = "linear"
        self.training = true
        self.in_features = in_features
        self.out_features = out_features
        self.bias_enabled = bias
        self.init_name = init_name
        self.weight = Parameter(tensor.zeros([in_features, out_features]), "weight")
        if bias:
            self.bias = Parameter(tensor.zeros([out_features]), "bias")
        else:
            self.bias = nil
        __apply_linear_init(self)

    fn forward(x):
        return functional.linear(__as_variable(x), self.weight, self.bias)

    fn parameters():
        return parameters(self)

    fn named_parameters():
        return named_parameters(self)

    fn buffers():
        return buffers(self)

    fn train():
        return train(self)

    fn eval():
        return eval(self)

    fn zero_grad():
        return zero_grad(self)

    fn state_dict():
        return state_dict(self)

    fn load_state_dict(state):
        return load_state_dict(self, state)

    fn save(path: String):
        return save(self, path)

fn linear(in_features: Int, out_features: Int, bias: Bool = true, init_name: String = "xavier_uniform"):
    return Linear(in_features, out_features, bias, init_name)

class ReLU:
    let kind: String
    var training: Bool

    fn init():
        self.kind = "relu"
        self.training = true

    fn forward(x):
        return functional.relu(__as_variable(x))

    fn parameters():
        return []

    fn named_parameters():
        return []

    fn buffers():
        return []

    fn train():
        self.training = true
        return self

    fn eval():
        self.training = false
        return self

    fn zero_grad():
        return self

    fn state_dict():
        return {}

    fn load_state_dict(state):
        return self

    fn save(path: String):
        return save(self, path)

fn relu():
    return ReLU()

