{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/tc39-proposal-json-modules/master/extensions/tmGrammar.schema.json",
  "name": "Aura",
  "scopeName": "source.aura",
  "fileTypes": ["aura"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#type_annotations" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#members" },
    { "include": "#calls" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.aura",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aura",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aura",
              "match": "\\\\(?:[nrt\"\\\\0]|u[0-9a-fA-F]{4})"
            },
            {
              "name": "meta.interpolation.aura",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.aura" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.aura" }
              },
              "patterns": [
                { "include": "#constants" },
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#members" },
                { "include": "#calls" },
                { "include": "#operators" },
                {
                  "name": "variable.other.readwrite.aura",
                  "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.aura",
          "match": "'(?:\\\\.|[^'\\\\])'"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.module.declaration.aura",
          "match": "\\b(module)\\s+([a-z_][a-zA-Z0-9_]*(?:\\.[a-z_][a-zA-Z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.module.aura" },
            "2": { "name": "entity.name.namespace.aura" }
          }
        },
        {
          "name": "meta.import.from.aura",
          "match": "\\b(from)\\s+([a-z_][a-zA-Z0-9_]*(?:\\.[a-z_][a-zA-Z0-9_]*)*)\\s+(import)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.control.import.aura" },
            "2": { "name": "entity.name.namespace.aura" },
            "3": { "name": "keyword.control.import.aura" },
            "4": { "name": "entity.name.import.aura" }
          }
        },
        {
          "name": "meta.import.aura",
          "match": "\\b(import)\\s+([a-z_][a-zA-Z0-9_]*(?:\\.[a-z_][a-zA-Z0-9_]*)*)(?:\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.control.import.aura" },
            "2": { "name": "entity.name.namespace.aura" },
            "3": { "name": "keyword.control.import.aura" },
            "4": { "name": "entity.name.alias.aura" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.collection.indexed.aura",
          "match": "\\b(indexed)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(by)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.indexed.aura" },
            "2": { "name": "variable.other.definition.aura" },
            "3": { "name": "keyword.declaration.indexed.aura" },
            "4": { "name": "variable.parameter.key.aura" }
          }
        },
        {
          "name": "meta.variable.declaration.aura",
          "match": "\\b(let|var)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.variable.aura" },
            "2": { "name": "variable.other.definition.aura" }
          }
        },
        {
          "name": "meta.function.definition.aura",
          "match": "\\b(async\\s+)?(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(<[^>\\n]+>)?",
          "captures": {
            "1": { "name": "storage.modifier.async.aura" },
            "2": { "name": "keyword.declaration.function.aura" },
            "3": { "name": "entity.name.function.aura" },
            "4": { "name": "meta.generic.parameters.aura" }
          }
        },
        {
          "name": "meta.type.definition.aura",
          "match": "\\b(class|struct|interface|trait|enum|actor|facet)\\s+([A-Z][a-zA-Z0-9_]*)\\b\\s*(<[^>\\n]+>)?",
          "captures": {
            "1": { "name": "keyword.declaration.type.aura" },
            "2": { "name": "entity.name.type.aura" },
            "3": { "name": "meta.generic.parameters.aura" }
          }
        },
        {
          "name": "meta.constraint.definition.aura",
          "match": "\\b(constraint)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.constraint.aura" },
            "2": { "name": "entity.name.type.constraint.aura" }
          }
        },
        {
          "name": "meta.unit.definition.aura",
          "match": "\\b(unit)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.units.aura" },
            "2": { "name": "entity.name.type.unit.aura" }
          }
        },
        {
          "name": "meta.impl.for.aura",
          "match": "\\b(impl)\\s+([A-Z][a-zA-Z0-9_]*)\\s+(for)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.impl.aura" },
            "2": { "name": "entity.name.type.trait.aura" },
            "3": { "name": "keyword.control.for.aura" },
            "4": { "name": "entity.name.type.aura" }
          }
        },
        {
          "name": "meta.impl.block.aura",
          "match": "\\b(impl)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.impl.aura" },
            "2": { "name": "entity.name.type.aura" }
          }
        },
        {
          "name": "meta.function.parameters.aura",
          "begin": "\\b(?:async\\s+)?fn\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s*(?:<[^>\\n]+>\\s*)?\\(",
          "end": "\\)",
          "patterns": [
            {
              "name": "variable.parameter.aura",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*(?::|=|,|\\)))"
            },
            { "include": "#type_annotations" },
            { "include": "#constants" },
            { "include": "#numbers" },
            { "include": "#strings" },
            { "include": "#operators" },
            {
              "name": "punctuation.separator.parameter.aura",
              "match": ","
            }
          ]
        }
      ]
    },
    "type_annotations": {
      "patterns": [
        {
          "name": "meta.type.annotation.measure.aura",
          "match": "(:)\\s*(measure)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.separator.type-annotation.aura" },
            "2": { "name": "storage.type.aura" },
            "3": { "name": "entity.name.type.unit.aura" }
          }
        },
        {
          "name": "meta.type.annotation.aura",
          "match": "(:)\\s*(Int(?:8|16|32|64)?|UInt(?:8|16|32|64)?|Float(?:32|64)?|Bool|Char|String|Bytes|List|Map|Set|Channel|Result|Option|Stack|Queue|LinkedList|HashMap|TreeMap|Heap|Indexed|[A-Z][a-zA-Z0-9_]*)(\\s*<[^>\\n]+>)?(\\?)?",
          "captures": {
            "1": { "name": "punctuation.separator.type-annotation.aura" },
            "2": { "name": "storage.type.aura" },
            "3": { "name": "meta.generic.arguments.aura" },
            "4": { "name": "keyword.operator.optional.aura" }
          }
        },
        {
          "name": "meta.return.type.aura",
          "match": "(->)\\s*(Int(?:8|16|32|64)?|UInt(?:8|16|32|64)?|Float(?:32|64)?|Bool|Char|String|Bytes|List|Map|Set|Channel|Result|Option|Stack|Queue|LinkedList|HashMap|TreeMap|Heap|Indexed|[A-Z][a-zA-Z0-9_]*)(\\s*<[^>\\n]+>)?(\\?)?",
          "captures": {
            "1": { "name": "keyword.operator.arrow.aura" },
            "2": { "name": "storage.type.aura" },
            "3": { "name": "meta.generic.arguments.aura" },
            "4": { "name": "keyword.operator.optional.aura" }
          }
        },
        {
          "name": "support.type.primitive.aura",
          "match": "\\b(Int|Int8|Int16|Int32|Int64|UInt|UInt8|UInt16|UInt32|UInt64|Float32|Float64|Bool|Char|String|Bytes|List|Map|Set|Channel|Result|Option|Stack|Queue|LinkedList|HashMap|TreeMap|Heap|Indexed|measure)\\b"
        },
        {
          "name": "entity.name.type.aura",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.aura",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.aura",
          "match": "\\bnil\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.measure.aura",
          "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "constant.numeric.hex.aura",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.aura",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.aura",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.aura",
          "match": "\\b[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)\\b"
        },
        {
          "name": "constant.numeric.integer.aura",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.aura",
          "match": "\\b(if|elif|else|for|in|while|repeat|cadence|as|break|continue|return|match|case)\\b"
        },
        {
          "name": "keyword.control.cadence.aura",
          "match": "\\b(start|first|each|between|last|empty)\\b(?=\\s*:)"
        },
        {
          "name": "keyword.declaration.constraint.aura",
          "match": "\\b(constraint|require)\\b"
        },
        {
          "name": "keyword.declaration.units.aura",
          "match": "\\b(unit|base|measure)\\b"
        },
        {
          "name": "keyword.declaration.facet.aura",
          "match": "\\b(facet|adopts)\\b"
        },
        {
          "name": "keyword.declaration.indexed.aura",
          "match": "\\b(indexed|by)\\b"
        },
        {
          "name": "keyword.control.error.aura",
          "match": "\\b(try|catch|throw|defer)\\b"
        },
        {
          "name": "keyword.control.async.aura",
          "match": "\\b(async|await|spawn|select)\\b"
        },
        {
          "name": "keyword.operator.logical.aura",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "storage.modifier.aura",
          "match": "\\b(pub|mut|weak)\\b"
        },
        {
          "name": "keyword.other.aura",
          "match": "\\b(where|is)\\b"
        },
        {
          "name": "variable.language.self.aura",
          "match": "\\bself\\b"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "meta.enum.constructor.aura",
          "match": "(?<![a-zA-Z0-9_])(\\.)([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "punctuation.accessor.dot.aura" },
            "2": { "name": "constant.other.enum-variant.aura" }
          }
        },
        {
          "name": "meta.method.call.aura",
          "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "punctuation.accessor.dot.aura" },
            "2": { "name": "entity.name.function.method.aura" }
          }
        },
        {
          "name": "meta.property.access.aura",
          "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "punctuation.accessor.dot.aura" },
            "2": { "name": "variable.other.property.aura" }
          }
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "support.function.builtin.aura",
          "match": "\\b(print|len|min|max|str|int|float|abs|sqrt|range|to_list|sum|sort|unique|top_k|freq|chunk|window|take|drop|panic)\\b(?=\\s*\\()"
        },
        {
          "name": "support.type.collection.aura",
          "match": "\\b(List|Stack|Queue|LinkedList|HashMap|TreeMap|Heap|Indexed)\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.call.aura",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.constructor.aura",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.aura",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.aura",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.aura",
          "match": "(\\*\\*|[+\\-*/%])"
        },
        {
          "name": "keyword.operator.bitwise.aura",
          "match": "(<<|>>|[&|^~])"
        },
        {
          "name": "keyword.operator.range.aura",
          "match": "\\.\\.(=)?"
        },
        {
          "name": "keyword.operator.pipeline.aura",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.aura",
          "match": "->"
        },
        {
          "name": "keyword.operator.nullish.aura",
          "match": "(\\?\\?|!|\\?)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.aura",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.aura",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.statement.aura",
          "match": ";"
        },
        {
          "name": "punctuation.brackets.aura",
          "match": "[()\\[\\]{}]"
        }
      ]
    }
  }
}
